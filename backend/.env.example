# MongoDB Configuration
# Get this from MongoDB Atlas > Connect > Connection String
MONGODB_URI=mongodb+srv://seo_vision_user:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/seo-vision?retryWrites=true&w=majority
DB_NAME=seo-vision

# Clerk Authentication
# Get these from Clerk Dashboard > API Keys
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxx
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx

# Server Configuration
PORT=5000
NODE_ENV=development

# Optional: Logging
LOG_LEVEL=debug
